---
// Native Astro game shell. All interactivity lives in ./game.client.ts,
// bundled by the <script> below — no framework runtime ships.
---

<!-- particle-field background; edge fades applied in-canvas -->
<div id="bg" class="pointer-events-none fixed inset-0 z-0">
	<canvas id="bg-field" class="block h-full w-full opacity-0"></canvas>
</div>

<main
	id="game"
	data-phase="idle"
	class="group relative z-10 flex min-h-svh flex-col px-5 data-[phase=idle]:items-center data-[phase=idle]:justify-center sm:px-10 lg:px-20"
>
	<!-- corner readouts; held hidden until the index loads to avoid a "0 of 0" flash -->
	<div
		id="readout"
		class="pointer-events-none absolute inset-x-0 top-0 flex items-center justify-between p-5 text-gray-500 text-sm opacity-0 transition-opacity duration-300 dark:text-gray-400"
	>
		<span><span id="counter">0</span> of <span id="total">0</span> named</span>
		<span id="hud" class="flex gap-4 tabular-nums" style="display:none">
			<span id="timer">1:00</span>
			<span>★ <span id="star">0</span></span>
		</span>
	</div>

	<!-- single-card display (left-aligned, crossfades between guesses) -->
	<div
		id="wall"
		class="relative flex-1 overflow-hidden group-data-[phase=idle]:hidden"
	></div>

	<!-- input -->
	<form id="form" class="t-input-wrap w-full group-data-[phase=playing]:pb-10">
		<div id="input-slot" class="relative w-full">
			<input
				id="input"
				class="t-input input h-auto w-full rounded-none border-x-0 border-t-0 border-b-4 border-gray-300 bg-transparent text-4xl capitalize text-gray-900 outline-none transition-colors duration-300 placeholder:normal-case placeholder:text-transparent focus:border-gray-900 sm:text-7xl lg:text-9xl dark:border-gray-700 dark:text-gray-100 dark:focus:border-gray-300"
				type="text"
				name="name"
				placeholder="Name a woman"
				autocomplete="off"
				spellcheck="false"
				disabled
			>
			<div
				class="fake-placeholder pointer-events-none absolute inset-0 text-4xl sm:text-7xl lg:text-9xl"
				aria-hidden="true"
			>
				Name a <span class="font-fraunces italic">woman</span>
			</div>
		</div>
		<p id="message" class="t-error-msg mt-2 min-h-5 text-sm"></p>
	</form>

	<!-- game over overlay -->
	<div
		id="over"
		class="absolute inset-0 flex flex-col items-center justify-center gap-4 bg-gray-50/90 dark:bg-gray-900/90"
		style="display:none"
	>
		<p class="text-2xl text-gray-600 dark:text-gray-300">Time! You named</p>
		<p id="final" class="text-8xl text-gray-900 dark:text-gray-100">0</p>
		<button
			id="again"
			type="button"
			class="flex items-center gap-2 rounded-full bg-gray-900 px-6 py-2 text-gray-50 transition-transform active:scale-95 dark:bg-gray-100 dark:text-gray-900"
		>
			Play Again
			<kbd
				class="inline-flex items-center gap-0.5 rounded border border-gray-50/30 px-1.5 py-0.5 text-xs dark:border-gray-900/30"
				aria-hidden="true"
			>
				<svg
					viewBox="0 0 24 24"
					class="h-3 w-3 fill-none stroke-current stroke-2"
					stroke-linecap="round"
					stroke-linejoin="round"
					role="img"
					aria-label="Enter"
				>
					<title>Enter</title>
					<path d="M9 10L4 15l5 5" />
					<path d="M20 4v7a4 4 0 0 1-4 4H4" />
				</svg>
			</kbd>
		</button>
	</div>
</main>

<script>
import "./game.client";
</script>
